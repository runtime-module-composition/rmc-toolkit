{
  "name": "runtime-module-composition",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./packages/core/dist/index.d.ts",
      "import": "./packages/core/dist/index.js"
    },
    "./core": {
      "types": "./packages/core/dist/index.d.ts",
      "import": "./packages/core/dist/index.js"
    },
    "./vite": {
      "types": "./packages/vite/dist/index.d.ts",
      "import": "./packages/vite/dist/index.js"
    },
    "./react": {
      "types": "./packages/react/dist/index.d.ts",
      "import": "./packages/react/dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "docs",
    "packages/*/dist",
    "README.md"
  ],
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "tsc -b packages/*",
    "clean": "tsc -b packages/* --clean",
    "test": "vitest run",
    "typecheck": "tsc -b packages/* --pretty false"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0",
    "react": "^19.0.0"
  }
}
